---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
  }).replace(',', '');
}
---

<BaseLayout
  title="Writing — Stop Think Pivot"
  description="All posts from Stop Think Pivot."
>
  <div style="padding: 4rem 0 6rem;">
    <div class="container">
      <div style="margin-bottom: 3rem;">
        <h1 style="margin-bottom: 0.4rem;">Writing</h1>
        <p style="color: var(--text-muted); font-style: italic;">
          Thoughts on stopping, thinking, and making moves.
        </p>
      </div>

      {posts.length > 0 ? (
        <div class="post-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="post-card">
              <div class="post-card__date">
                {formatDate(post.data.pubDate)}
              </div>
              <div>
                <div class="post-card__title">{post.data.title}</div>
                <p class="post-card__excerpt">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="post-card__tags">
                    {post.data.tags.map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="color: var(--text-muted); font-style: italic;">Nothing here yet.</p>
      )}
    </div>
  </div>
</BaseLayout>
